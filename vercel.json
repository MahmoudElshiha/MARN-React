{
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://marn.runasp.net/api/$1"
        },
        {
            "source": "/images/(.*)",
            "destination": "https://marn.runasp.net/images/$1"
        },
        {
            "source": "/hubs/(.*)",
            "destination": "https://marn.runasp.net/hubs/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}