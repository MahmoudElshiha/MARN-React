{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "rewrites": [
        { "source": "/api/:path*", "destination": "https://marn.runasp.net/api/:path*" },
        { "source": "/images/:path*", "destination": "https://marn.runasp.net/images/:path*" },
        { "source": "/hubs/:path*", "destination": "https://marn.runasp.net/hubs/:path*" },
        { "source": "/((?!api|images|hubs).*)", "destination": "/index.html" }
    ]
}